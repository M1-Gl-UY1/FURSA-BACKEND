# ============================================================================
# FURSA Backend - Variables d'environnement
# ============================================================================
# Copier ce fichier en .env et remplir les vraies valeurs.
# NE JAMAIS committer le .env (il est dans .gitignore).
# ============================================================================

# --- Profil Spring ------------------------------------------------------------
# 'dev' en local (ddl-auto=update, logs DEBUG, DataSeeder actif)
# 'prod' en production (ddl-auto=validate, logs INFO, DataSeeder desactive)
SPRING_PROFILES_ACTIVE=dev

# --- Base de donnees PostgreSQL -----------------------------------------------
POSTGRES_DB=fursa
POSTGRES_USER=postgres
# OBLIGATOIRE - pas de valeur par defaut.
POSTGRES_PASSWORD=change_me

# --- JWT ---------------------------------------------------------------------
# OBLIGATOIRE, minimum 32 caracteres. Ne jamais reutiliser entre environnements.
# Generation : openssl rand -base64 48
JWT_SECRET=REPLACE_ME_WITH_openssl_rand_base64_48

# Duree du token en millisecondes (defaut 24h).
JWT_EXPIRATION_MS=86400000

# --- CORS --------------------------------------------------------------------
# Liste d'origines autorisees separees par des virgules.
# NE JAMAIS mettre * en prod (empeche les credentials).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
